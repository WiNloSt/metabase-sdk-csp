# Copy to auth-server/.env and fill in. Loaded by `npm start` (node --env-file-if-exists).
# .env is gitignored.

# Admin > Settings > Authentication > JWT > "String used by the JWT signing key".
METABASE_JWT_SHARED_SECRET=

# Optional overrides.
MB_USER_EMAIL=csp-harness@example.com
AUTH_PORT=8089
