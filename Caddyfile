# Strict-CSP harness for EMB-1764.
#
# Serves the built SDK app at http://csp.localhost:8088 with a strict
# Content-Security-Policy that mirrors a real customer page: the Metabase instance
# origin is allowed in connect-src (the SDK needs it for data calls), but the
# Snowplow collector (http://localhost:9090 / sp.metabase.com) is deliberately
# NOT. That is the whole point — a direct collector POST must be CSP-blocked,
# while the POST to the instance proxy (/api/analytics/snowplow-proxy) must pass.
#
# csp.localhost is a distinct host from the instance (localhost:3000), so it
# behaves like a real third-party customer origin — cookies and origin don't
# bleed across ports. Browsers resolve *.localhost to 127.0.0.1 automatically.
# The http:// prefix keeps Caddy on plain HTTP (no TLS provisioning).
#
# The JWT provider is reverse-proxied under the SAME origin, so it counts as
# 'self' — exactly how a customer co-locates their auth backend with their app.

http://csp.localhost:8088 {
	# Customer's JWT signing backend (the auth-server), same-origin via proxy.
	# Caddy runs in Docker; the auth-server (node) runs on the host.
	handle /sso/metabase* {
		reverse_proxy host.docker.internal:8089
	}

	# The static SDK app (app/dist is mounted at /srv in the container).
	handle {
		root * /srv
		encode gzip
		try_files {path} /index.html
		file_server
	}

	# Strict CSP. Note what is ABSENT from connect-src: the Snowplow collector.
	# If something legit is blocked, widen the relevant directive — but NEVER add
	# the collector host, or the test loses its meaning.
	header {
		# script-src must include the Metabase origin: the npm package is a thin
		# loader that injects <script src="{instanceUrl}/app/embedding-sdk.js">
		# and the bootstrap pulls more chunks from the instance. Without :3000
		# here the SDK never loads. (connect-src 'self' covers the SDK's data and
		# the snowplow-proxy POST; the collector :9090 stays absent on purpose.)
		#
		# DEV-ONLY: the ws://...:8080 entries are webpack-dev-server's HMR socket,
		# present only because the instance runs `build-hot`. A real customer
		# serving a production SDK bundle would NOT need these. They are unrelated
		# to the SDK/telemetry; allowed here just to silence the console. The
		# collector (:9090) is still absent, so the strict-CSP test is intact.
		Content-Security-Policy "default-src 'self'; connect-src 'self' http://localhost:3000 ws://csp.localhost:8080 ws://localhost:8080; script-src 'self' http://localhost:3000; style-src 'self' 'unsafe-inline' http://localhost:3000; img-src 'self' http://localhost:3000 data: blob:; font-src 'self' http://localhost:3000 data:; worker-src 'self' blob:"
		# Make the CSP observable in the response for quick sanity checks.
		-Server
	}
}
